# --- Trading mode -----------------------------------------------------------
# "paper" (default): simulated fills against real market prices; no API key needed.
# "live": real orders on the exchange selected below.
TRADING_MODE=paper
EXCHANGE=coinbase                     # coinbase | robinhood (live-mode venue)

# --- Coinbase API key (live + EXCHANGE=coinbase) -----------------------------
# Create at https://portal.cdp.coinbase.com/access/api
# CRITICAL: grant ONLY "View" and "Trade" permissions. NEVER grant "Transfer".
# The agent checks this at startup and refuses to run with a transfer-capable key.
# Strongly recommended: scope the key to a dedicated portfolio holding only the
# money you are prepared to lose.
COINBASE_API_KEY_NAME=organizations/xxxxxxxx/apiKeys/xxxxxxxx
COINBASE_API_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----\n"

# --- Robinhood API key (live + EXCHANGE=robinhood) ---------------------------
# Create at Robinhood -> Account -> Settings -> Crypto -> API trading:
# generate an Ed25519 keypair, register the PUBLIC key there, keep the private
# key seed (base64) here. The Robinhood Crypto API has no withdrawal/transfer
# endpoints at all, so trade-only is structural. NOTE: Robinhood has no
# sub-portfolios — the key sees your whole crypto account, so set
# PORTFOLIO_FLOOR_USD and MAX_TRADE_USD deliberately.
ROBINHOOD_API_KEY=rh-api-key-uuid
ROBINHOOD_PRIVATE_KEY=base64-ed25519-private-key-seed

# --- Risk configuration -----------------------------------------------------
DEFAULT_RISK_MODE=conservative        # conservative | moderate | aggressive
MAX_TRADE_USD=250                     # hard per-buy cap regardless of mode
MIN_TRADE_USD=5                       # trades smaller than this are skipped
QUOTE_CURRENCY=USD                    # USD or USDC (Robinhood requires USD)
PRODUCT_WHITELIST=BTC,ETH,SOL,XRP,ADA,DOGE,AVAX,LINK,LTC,DOT
PORTFOLIO_FLOOR_USD=0                 # >0: if total value hits this, liquidate
                                      # everything and halt (no override)
SHOCK_DROP_PCT=8                      # held coin -8%/1h (or -16%/24h) raises a
                                      # REVIEW_REQUIRED alert for the analyst

# Small accounts (e.g. ~$50): the % caps shrink trades below MIN_TRADE_USD and
# nothing will ever execute. A working small-account profile:
#   DEFAULT_RISK_MODE=moderate  MIN_TRADE_USD=2  MAX_TRADE_USD=15
#   PORTFOLIO_FLOOR_USD=30

# --- Double-check workflow ---------------------------------------------------
REQUIRE_CONFIRMATION=1                # 1: analyst must confirm every proposed trade
PROPOSAL_TTL_MINUTES=15               # unconfirmed proposals expire
CHALLENGE_WINDOW_HOURS=24             # how long a BUY can be challenged/unwound
FEE_GATE_PCT=1.5                      # min expected move (%) for a buy to be worth its fees
LOCK_RISK_CONTROLS=0                  # 1: only the operator (not the analyst) can change
                                      # risk mode or re-enable trading after a halt

# --- Paper mode --------------------------------------------------------------
PAPER_STARTING_USD=10000
PAPER_FEE_RATE=0.006                  # simulated taker fee (0.6%)

# --- Storage -----------------------------------------------------------------
# AGENT_DATA_DIR=~/.coinbase-trading-agent
